# Required: password to access the app
APP_PASSWORD=changeme

# Required: secret key for signing session cookies
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string

# Optional: database URL (defaults to SQLite at data/prod_killer.db)
# DATABASE_URL=sqlite:///./data/prod_killer.db

# Optional: set to "true" to seed the database with test data on startup
# Only seeds if the database is empty
SEED_DATA=false
